<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PomodoroTimer.App"
             xmlns:local="using:PomodoroTimer"
             RequestedThemeVariant="Light">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://PomodoroTimer/Styles/Colors.axaml" />
                <ResourceInclude Source="avares://PomodoroTimer/Styles/DesignTokens.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://PomodoroTimer/Styles/Typography.axaml" />
        <StyleInclude Source="avares://PomodoroTimer/Styles/Controls.axaml" />
    </Application.Styles>
</Application>
