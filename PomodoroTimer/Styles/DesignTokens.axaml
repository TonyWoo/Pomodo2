<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">
    <sys:Double x:Key="Size.TouchTarget">44</sys:Double>
    <sys:Double x:Key="Size.NavRailWidth">76</sys:Double>
    <sys:Double x:Key="Size.SidePanelWidth">278</sys:Double>
    <sys:Double x:Key="Size.TimerDialDesktop">330</sys:Double>
    <sys:Double x:Key="Size.TimerDialMobile">270</sys:Double>
    <CornerRadius x:Key="Radius.Small">8</CornerRadius>
    <CornerRadius x:Key="Radius.Medium">8</CornerRadius>
    <CornerRadius x:Key="Radius.Large">8</CornerRadius>
    <CornerRadius x:Key="Radius.Pill">999</CornerRadius>
    <Thickness x:Key="Thickness.Card">16</Thickness>
    <Thickness x:Key="Thickness.Page">18</Thickness>
</ResourceDictionary>
