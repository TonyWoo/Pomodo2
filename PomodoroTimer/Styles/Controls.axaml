<Styles xmlns="https://github.com/avaloniaui">
    <Style Selector="Button">
        <Setter Property="MinHeight" Value="{StaticResource Size.Control.MinHeight}" />
        <Setter Property="Padding" Value="{StaticResource Space.Control}" />
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Control}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="FontSize" Value="{StaticResource FontSize.BodyLarge}" />
    </Style>

    <Style Selector="Button.primary">
        <Setter Property="Background" Value="{StaticResource Brush.Brand.Red}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Brand.White}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Brand.Red}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Button.secondary">
        <Setter Property="Background" Value="{StaticResource Brush.Surface.Primary}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
        <Setter Property="BorderThickness" Value="1" />
    </Style>

    <Style Selector="Button.icon">
        <Setter Property="MinWidth" Value="{StaticResource Size.Control.MinHeight}" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="ToggleButton.nav">
        <Setter Property="MinHeight" Value="{StaticResource Size.Control.MinHeight}" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Control}" />
        <Setter Property="HorizontalContentAlignment" Value="Left" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Secondary}" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="ToggleButton.nav:checked">
        <Setter Property="Background" Value="{StaticResource Brush.Brand.Red.Subtle}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Brand.Red}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Brand.Red.Soft}" />
    </Style>

    <Style Selector="Border.card">
        <Setter Property="Background" Value="{StaticResource Brush.Surface.Primary}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Card}" />
        <Setter Property="Padding" Value="{StaticResource Space.Panel}" />
    </Style>

    <Style Selector="Border.subtleCard">
        <Setter Property="Background" Value="{StaticResource Brush.Surface.Secondary}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Card}" />
        <Setter Property="Padding" Value="{StaticResource Space.Panel}" />
    </Style>

    <Style Selector="TextBox">
        <Setter Property="MinHeight" Value="{StaticResource Size.Control.MinHeight}" />
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Control}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        <Setter Property="Background" Value="{StaticResource Brush.Surface.Primary}" />
    </Style>

    <Style Selector="NumericUpDown">
        <Setter Property="MinHeight" Value="{StaticResource Size.Control.MinHeight}" />
        <Setter Property="CornerRadius" Value="{StaticResource Radius.Control}" />
        <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Subtle}" />
        <Setter Property="Foreground" Value="{StaticResource Brush.Text.Primary}" />
        <Setter Property="Background" Value="{StaticResource Brush.Surface.Primary}" />
    </Style>
</Styles>
