<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PomodoroTimer.ViewModels"
             xmlns:controls="using:PomodoroTimer.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1080"
             d:DesignHeight="720"
             x:Class="PomodoroTimer.Views.TimerView"
             x:DataType="vm:TimerViewModel">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="{DynamicResource Thickness.Page}">
            <Grid IsVisible="{Binding IsWideLayout}"
                  ColumnDefinitions="*,320">
                <StackPanel Grid.Column="0"
                            Spacing="18">
                    <Border Classes="card"
                            MinHeight="520">
                        <StackPanel Spacing="24"
                                    HorizontalAlignment="Center">
                            <TextBlock Text="{Binding StatusText}"
                                       Classes="caption"
                                       HorizontalAlignment="Center" />

                            <Grid Width="{DynamicResource Size.TimerDialDesktop}"
                                  Height="{DynamicResource Size.TimerDialDesktop}">
                                <controls:CircularTimerProgress Progress="{Binding Progress}"
                                                                TrackBrush="{DynamicResource Brush.Black.08}"
                                                                ProgressBrush="{DynamicResource Brush.Brand.Red}"
                                                                StrokeThickness="18" />
                                <StackPanel HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Spacing="12">
                                    <Grid Width="44"
                                          Height="44"
                                          HorizontalAlignment="Center">
                                        <Ellipse Fill="{DynamicResource Brush.Brand.Red}" />
                                        <Path Stroke="{DynamicResource Brush.Brand.White}"
                                              StrokeThickness="2"
                                              StrokeLineCap="Round"
                                              Data="M 22 22 L 29 15 M 22 22 L 15 29" />
                                    </Grid>
                                    <TextBlock Text="{Binding RemainingTimeText}"
                                               FontSize="64"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource Brush.Text.Primary}"
                                               HorizontalAlignment="Center"
                                               TextWrapping="NoWrap" />
                                    <Border Background="{DynamicResource Brush.Black.04}"
                                            CornerRadius="{DynamicResource Radius.Pill}"
                                            Padding="18,8"
                                            HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding BreakHintText}"
                                                   FontSize="15"
                                                   Foreground="{DynamicResource Brush.Text.Secondary}"
                                                   TextWrapping="NoWrap" />
                                    </Border>
                                    <TextBlock Text="{Binding ModeText}"
                                               Classes="caption"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto"
                                  Width="520">
                                <Button Grid.Column="0"
                                        Classes="primary"
                                        Command="{Binding PrimaryCommand}"
                                        Content="{Binding PrimaryActionText}" />
                                <Button Grid.Column="1"
                                        Classes="secondary"
                                        Margin="12,0,0,0"
                                        Command="{Binding ResetCommand}"
                                        Content="{Binding ResetText}" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Classes="card">
                        <StackPanel Spacing="10">
                            <TextBlock Text="{Binding TopicLabel}"
                                       FontWeight="SemiBold" />
                            <TextBox Text="{Binding Topic}"
                                     PlaceholderText="{Binding TopicPlaceholder}" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Margin="22,0,0,0"
                            Spacing="18">
                    <Border Classes="card">
                        <Grid ColumnDefinitions="Auto,*">
                            <Grid Width="48"
                                  Height="48">
                                <Ellipse Fill="{DynamicResource Brush.Brand.Red}" />
                                <Path Stroke="{DynamicResource Brush.Brand.White}"
                                      StrokeThickness="2"
                                      StrokeLineCap="Round"
                                      Data="M 24 24 L 31 17 M 24 24 L 17 31" />
                            </Grid>
                            <StackPanel Grid.Column="1"
                                        Margin="14,0,0,0">
                                <TextBlock Text="{Binding TodayPomodorosLabel}"
                                           Classes="caption" />
                                <TextBlock Text="{Binding TodayPomodorosText}"
                                           Classes="metricValue" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Classes="card">
                        <StackPanel Spacing="14">
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="{Binding TodayTasksLabel}"
                                           Classes="sectionTitle" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding ViewAllText}"
                                           Classes="caption"
                                           VerticalAlignment="Center" />
                            </Grid>

                            <Grid ColumnDefinitions="*,70,72,82"
                                  IsVisible="{Binding HasTodaySessions}">
                                <TextBlock Text="{Binding SessionTopicHeader}"
                                           Classes="caption" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding SessionCompletedAtHeader}"
                                           Classes="caption" />
                                <TextBlock Grid.Column="2"
                                           Text="{Binding SessionDurationHeader}"
                                           Classes="caption" />
                                <TextBlock Grid.Column="3"
                                           Text="{Binding SessionStatusHeader}"
                                           Classes="caption" />
                            </Grid>

                            <ItemsControl ItemsSource="{Binding TodaySessions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:SessionListItemViewModel">
                                        <Grid ColumnDefinitions="*,70,72,82"
                                              Margin="0,6">
                                            <TextBlock Text="{Binding Topic}"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding CompletedAtText}"
                                                       Classes="caption" />
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding DurationText}"
                                                       Classes="caption" />
                                            <TextBlock Grid.Column="3"
                                                       Text="{Binding StatusText}"
                                                       Classes="caption" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="{Binding EmptySessionsText}"
                                       Classes="caption"
                                       IsVisible="{Binding HasNoTodaySessions}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <StackPanel IsVisible="{Binding IsCompactLayout}"
                        Spacing="16">
                <Border Classes="card">
                    <StackPanel Spacing="18">
                        <Grid Width="{DynamicResource Size.TimerDialMobile}"
                              Height="{DynamicResource Size.TimerDialMobile}"
                              HorizontalAlignment="Center">
                            <controls:CircularTimerProgress Progress="{Binding Progress}"
                                                            TrackBrush="{DynamicResource Brush.Black.08}"
                                                            ProgressBrush="{DynamicResource Brush.Brand.Red}"
                                                            StrokeThickness="16" />
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="10">
                                <TextBlock Text="{Binding StatusText}"
                                           Classes="caption"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="{Binding RemainingTimeText}"
                                           FontSize="50"
                                           FontWeight="Bold"
                                           TextWrapping="NoWrap" />
                                <Border Background="{DynamicResource Brush.Black.04}"
                                        CornerRadius="{DynamicResource Radius.Pill}"
                                        Padding="14,7"
                                        HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding BreakHintText}"
                                               Classes="caption"
                                               TextWrapping="NoWrap" />
                                </Border>
                            </StackPanel>
                        </Grid>

                        <StackPanel Spacing="10">
                            <TextBlock Text="{Binding TopicLabel}"
                                       FontWeight="SemiBold" />
                            <TextBox Text="{Binding Topic}"
                                     PlaceholderText="{Binding TopicPlaceholder}" />
                        </StackPanel>

                        <Button Classes="primary"
                                Command="{Binding PrimaryCommand}"
                                Content="{Binding PrimaryActionText}" />
                        <Button Classes="secondary"
                                Command="{Binding ResetCommand}"
                                Content="{Binding ResetText}" />
                    </StackPanel>
                </Border>

                <Border Classes="card">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Grid Width="42"
                              Height="42">
                            <Ellipse Fill="{DynamicResource Brush.Brand.Red}" />
                            <Path Stroke="{DynamicResource Brush.Brand.White}"
                                  StrokeThickness="2"
                                  StrokeLineCap="Round"
                                  Data="M 21 21 L 28 14 M 21 21 L 14 28" />
                        </Grid>
                        <StackPanel Grid.Column="1"
                                    Margin="12,0,0,0">
                            <TextBlock Text="{Binding TodayPomodorosLabel}"
                                       Classes="caption" />
                            <TextBlock Text="{Binding TodayPomodorosText}"
                                       Classes="metricValue" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Classes="card">
                    <StackPanel Spacing="12">
                        <TextBlock Text="{Binding TodayTasksLabel}"
                                   Classes="sectionTitle" />
                        <ItemsControl ItemsSource="{Binding TodaySessions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:SessionListItemViewModel">
                                    <Grid ColumnDefinitions="*,Auto"
                                          Margin="0,7">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Topic}"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding DurationText}"
                                                       Classes="caption" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1"
                                                    HorizontalAlignment="Right">
                                            <TextBlock Text="{Binding CompletedAtText}"
                                                       Classes="caption" />
                                            <TextBlock Text="{Binding StatusText}"
                                                       Classes="caption" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="{Binding EmptySessionsText}"
                                   Classes="caption"
                                   IsVisible="{Binding HasNoTodaySessions}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
