<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PomodoroTimer.ViewModels"
             xmlns:controls="using:PomodoroTimer.Controls"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="824"
             d:DesignHeight="560"
             x:Class="PomodoroTimer.Views.TimerView"
             x:DataType="vm:TimerViewModel">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="{DynamicResource Thickness.Page}">
            <Grid IsVisible="{Binding IsWideLayout}"
                  ColumnDefinitions="*,294">
                <StackPanel Grid.Column="0"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Stretch"
                            Spacing="14">

                    <Border Classes="card"
                            HorizontalAlignment="Stretch"
                            MaxWidth="480">
                        <StackPanel Spacing="14">
                            <TextBlock Text="{Binding StatusText}"
                                       Classes="caption"
                                       HorizontalAlignment="Center" />

                    <Grid Width="{DynamicResource Size.TimerDialDesktop}"
                          Height="{DynamicResource Size.TimerDialDesktop}"
                          HorizontalAlignment="Center">
                        <controls:CircularTimerProgress Progress="{Binding Progress}"
                                                        TrackBrush="{DynamicResource Brush.Black.08}"
                                                        ProgressBrush="{DynamicResource Brush.Brand.Red}"
                                                        StrokeThickness="17" />
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Spacing="8">
                            <Image Width="46"
                                   Height="46"
                                   HorizontalAlignment="Center"
                                   Source="/Assets/tomato-app-icon.png" />
                            <TextBlock Text="{Binding RemainingTimeText}"
                                       FontSize="62"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource Brush.Text.Primary}"
                                       HorizontalAlignment="Center"
                                       TextWrapping="NoWrap" />
                            <Border Background="{DynamicResource Brush.Black.04}"
                                    CornerRadius="{DynamicResource Radius.Pill}"
                                    Padding="16,7"
                                    HorizontalAlignment="Center">
                                <TextBlock Text="{Binding BreakHintText}"
                                           FontSize="14"
                                           Foreground="{DynamicResource Brush.Text.Secondary}"
                                           TextWrapping="NoWrap" />
                            </Border>
                            <TextBlock Text="{Binding ModeText}"
                                       Classes="caption"
                                       HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>

                    <Grid ColumnDefinitions="*,*,*"
                          HorizontalAlignment="Center">
                        <Button Grid.Column="0"
                                Classes="secondary"
                                Command="{Binding StartCommand}">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8"
                                        HorizontalAlignment="Center">
                                <Path Width="14"
                                      Height="14"
                                      Fill="{DynamicResource Brush.Brand.Red}"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Data="M 2 1 L 13 7 L 2 13 Z" />
                                <TextBlock Text="{Binding StartActionText}"
                                           Foreground="{DynamicResource Brush.Brand.Red}"
                                           FontWeight="SemiBold"
                                           TextWrapping="NoWrap" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="1"
                                Classes="primary"
                                Margin="10,0"
                                Command="{Binding PauseCommand}">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8"
                                        HorizontalAlignment="Center">
                                <Grid Width="14"
                                      Height="14"
                                      ColumnDefinitions="*,*"
                                      ColumnSpacing="4"
                                      VerticalAlignment="Center">
                                    <Rectangle Fill="{DynamicResource Brush.Brand.White}" />
                                    <Rectangle Grid.Column="1"
                                               Fill="{DynamicResource Brush.Brand.White}" />
                                </Grid>
                                <TextBlock Text="{Binding PauseText}"
                                           Foreground="{DynamicResource Brush.Brand.White}"
                                           FontWeight="SemiBold"
                                           TextWrapping="NoWrap" />
                            </StackPanel>
                        </Button>
                        <Button Grid.Column="2"
                                Classes="secondary"
                                Command="{Binding ResetCommand}">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8"
                                        HorizontalAlignment="Center">
                                <Path Width="15"
                                      Height="15"
                                      Fill="{DynamicResource Brush.Text.Primary}"
                                      Stretch="Uniform"
                                      VerticalAlignment="Center"
                                      Data="M 8 1 C 4.5 1 1.7 3.6 1.3 7 L 0 7 L 2.6 10 L 5.1 7 L 3.6 7 C 4 4.8 5.8 3.2 8 3.2 C 10.7 3.2 12.8 5.3 12.8 8 C 12.8 10.7 10.7 12.8 8 12.8 C 6.7 12.8 5.5 12.3 4.7 11.5 L 3.2 13 C 4.4 14.2 6.1 15 8 15 C 11.9 15 15 11.9 15 8 C 15 4.1 11.9 1 8 1 Z" />
                                <TextBlock Text="{Binding ResetText}"
                                           Foreground="{DynamicResource Brush.Text.Primary}"
                                           FontWeight="SemiBold"
                                           TextWrapping="NoWrap" />
                            </StackPanel>
                        </Button>
                    </Grid>
                        </StackPanel>
                    </Border>

                    <Border Classes="card"
                            HorizontalAlignment="Stretch"
                            MaxWidth="480">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{Binding TopicLabel}"
                                       FontWeight="SemiBold" />
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="10">
                                <TextBox Text="{Binding Topic}"
                                         PlaceholderText="{Binding TopicPlaceholder}" />
                                <Button Grid.Column="1"
                                        Classes="secondary"
                                        Command="{Binding AddTaskCommand}">
                                    <TextBlock Text="{Binding AddTaskText}"
                                               FontWeight="SemiBold"
                                               TextWrapping="NoWrap" />
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Margin="18,0,0,0"
                            VerticalAlignment="Top"
                            Spacing="14">
                    <Border Classes="card">
                        <Grid ColumnDefinitions="Auto,*">
                            <Image Width="52"
                                   Height="52"
                                   Source="/Assets/tomato-app-icon.png" />
                            <StackPanel Grid.Column="1"
                                        Margin="12,0,0,0">
                                <TextBlock Text="{Binding TodayPomodorosLabel}"
                                           Classes="caption"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{Binding TodayPomodorosText}"
                                           Classes="metricValue" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Classes="card">
                        <StackPanel Spacing="12">
                            <TextBlock Text="{Binding TodayTasksLabel}"
                                       Classes="sectionTitle"
                                       FontSize="15" />

                            <ItemsControl ItemsSource="{Binding TodayTasks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:TaskListItemViewModel">
                                        <Border Classes="taskItem"
                                                Margin="0,6,0,0">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Title}"
                                                           FontWeight="SemiBold"
                                                           FontSize="13"
                                                           TextWrapping="Wrap" />
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <StackPanel Orientation="Horizontal"
                                                                Spacing="8"
                                                                VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding PomodoroCountText}"
                                                                   Classes="caption"
                                                                   FontSize="11" />
                                                        <TextBlock Text="{Binding CompletionText}"
                                                                   Classes="caption"
                                                                   FontSize="11" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1"
                                                                Orientation="Horizontal"
                                                                Spacing="4">
                                                        <Button Classes="taskActionButton"
                                                                Command="{Binding UseTaskCommand}"
                                                                ToolTip.Tip="{Binding UseTaskTooltip}">
                                                            <Path Width="10"
                                                                  Height="10"
                                                                  Stretch="Uniform"
                                                                  Fill="{DynamicResource Brush.Brand.Red}"
                                                                  Data="M 2 1 L 11 6 L 2 11 Z" />
                                                        </Button>
                                                        <Button Classes="taskActionButton"
                                                                Command="{Binding ToggleCompletedCommand}"
                                                                ToolTip.Tip="{Binding ToggleTooltip}">
                                                            <Path Width="10"
                                                                  Height="10"
                                                                  Stretch="Uniform"
                                                                  Fill="{DynamicResource Brush.Text.Primary}"
                                                                  Data="M 10.8 2.2 L 5.5 10.8 L 2.2 7.5 L 3.6 6.1 L 5.3 7.8 L 9.1 1.6 Z" />
                                                        </Button>
                                                        <Button Classes="taskActionButton"
                                                                Command="{Binding DeleteTaskCommand}"
                                                                ToolTip.Tip="{Binding DeleteTaskTooltip}">
                                                            <Path Width="10"
                                                                  Height="10"
                                                                  Stretch="Uniform"
                                                                  Fill="{DynamicResource Brush.Text.Secondary}"
                                                                  Data="M 4 1 L 4.7 0 L 7.3 0 L 8 1 L 11 1 L 11 2.5 L 1 2.5 L 1 1 Z M 2.2 3.5 L 9.8 3.5 L 9.1 12 L 2.9 12 Z M 4 5 L 5.4 5 L 5.4 10.5 L 4 10.5 Z M 6.6 5 L 8 5 L 8 10.5 L 6.6 10.5 Z" />
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <TextBlock Text="{Binding EmptyTasksText}"
                                       Classes="caption"
                                       IsVisible="{Binding HasNoTodayTasks}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <StackPanel IsVisible="{Binding IsCompactLayout}"
                        Spacing="14">
                <Border Classes="card">
                    <StackPanel Spacing="16">
                        <Grid Width="{DynamicResource Size.TimerDialMobile}"
                              Height="{DynamicResource Size.TimerDialMobile}"
                              HorizontalAlignment="Center">
                            <controls:CircularTimerProgress Progress="{Binding Progress}"
                                                            TrackBrush="{DynamicResource Brush.Black.08}"
                                                            ProgressBrush="{DynamicResource Brush.Brand.Red}"
                                                            StrokeThickness="15" />
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Spacing="8">
                                <Image Width="40"
                                       Height="40"
                                       HorizontalAlignment="Center"
                                       Source="/Assets/tomato-app-icon.png" />
                                <TextBlock Text="{Binding RemainingTimeText}"
                                           FontSize="48"
                                           FontWeight="Bold"
                                           TextWrapping="NoWrap" />
                                <Border Background="{DynamicResource Brush.Black.04}"
                                        CornerRadius="{DynamicResource Radius.Pill}"
                                        Padding="14,7"
                                        HorizontalAlignment="Center">
                                    <TextBlock Text="{Binding BreakHintText}"
                                               Classes="caption"
                                               TextWrapping="NoWrap" />
                                </Border>
                            </StackPanel>
                        </Grid>

                        <StackPanel Spacing="8">
                            <TextBlock Text="{Binding TopicLabel}"
                                       FontWeight="SemiBold" />
                            <Grid ColumnDefinitions="*,Auto"
                                  ColumnSpacing="10">
                                <TextBox Text="{Binding Topic}"
                                         PlaceholderText="{Binding TopicPlaceholder}" />
                                <Button Grid.Column="1"
                                        Classes="secondary"
                                        Command="{Binding AddTaskCommand}">
                                    <TextBlock Text="{Binding AddTaskText}"
                                               FontWeight="SemiBold"
                                               TextWrapping="NoWrap" />
                                </Button>
                            </Grid>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                            <Button Classes="primary"
                                    Command="{Binding PrimaryCommand}">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8"
                                            HorizontalAlignment="Center">
                                    <Grid Width="14"
                                          Height="14"
                                          VerticalAlignment="Center">
                                        <Path IsVisible="{Binding IsNotRunning}"
                                              Fill="{DynamicResource Brush.Brand.White}"
                                              Stretch="Uniform"
                                              Data="M 2 1 L 13 7 L 2 13 Z" />
                                        <Grid IsVisible="{Binding IsRunning}"
                                              ColumnDefinitions="*,*"
                                              ColumnSpacing="4">
                                            <Rectangle Fill="{DynamicResource Brush.Brand.White}" />
                                            <Rectangle Grid.Column="1"
                                                       Fill="{DynamicResource Brush.Brand.White}" />
                                        </Grid>
                                    </Grid>
                                    <TextBlock Text="{Binding PrimaryActionText}"
                                               Foreground="{DynamicResource Brush.Brand.White}"
                                               FontWeight="SemiBold"
                                               TextWrapping="NoWrap" />
                                </StackPanel>
                            </Button>
                            <Button Classes="secondary"
                                    Command="{Binding ResetCommand}">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8"
                                            HorizontalAlignment="Center">
                                    <Path Width="15"
                                          Height="15"
                                          Fill="{DynamicResource Brush.Text.Primary}"
                                          Stretch="Uniform"
                                          Data="M 8 1 C 4.5 1 1.7 3.6 1.3 7 L 0 7 L 2.6 10 L 5.1 7 L 3.6 7 C 4 4.8 5.8 3.2 8 3.2 C 10.7 3.2 12.8 5.3 12.8 8 C 12.8 10.7 10.7 12.8 8 12.8 C 6.7 12.8 5.5 12.3 4.7 11.5 L 3.2 13 C 4.4 14.2 6.1 15 8 15 C 11.9 15 15 11.9 15 8 C 15 4.1 11.9 1 8 1 Z" />
                                    <TextBlock Text="{Binding ResetText}"
                                               Foreground="{DynamicResource Brush.Text.Primary}"
                                               FontWeight="SemiBold"
                                               TextWrapping="NoWrap" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Classes="card">
                    <Grid ColumnDefinitions="Auto,*">
                        <Image Width="46"
                               Height="46"
                               Source="/Assets/tomato-app-icon.png" />
                        <StackPanel Grid.Column="1"
                                    Margin="12,0,0,0">
                            <TextBlock Text="{Binding TodayPomodorosLabel}"
                                       Classes="caption" />
                            <TextBlock Text="{Binding TodayPomodorosText}"
                                       Classes="metricValue" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Classes="card">
                    <StackPanel Spacing="12">
                        <TextBlock Text="{Binding TodayTasksLabel}"
                                   Classes="sectionTitle" />
                        <ItemsControl ItemsSource="{Binding TodayTasks}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:TaskListItemViewModel">
                                    <Border Classes="taskItem"
                                            Margin="0,7,0,0">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding Title}"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                            <Grid ColumnDefinitions="*,Auto">
                                                <StackPanel Orientation="Horizontal"
                                                            Spacing="8"
                                                            VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding PomodoroCountText}"
                                                               Classes="caption" />
                                                    <TextBlock Text="{Binding CompletionText}"
                                                               Classes="caption" />
                                                </StackPanel>
                                                <StackPanel Grid.Column="1"
                                                            Orientation="Horizontal"
                                                            Spacing="4">
                                                    <Button Classes="taskActionButton"
                                                            Command="{Binding UseTaskCommand}"
                                                            ToolTip.Tip="{Binding UseTaskTooltip}">
                                                        <Path Width="10"
                                                              Height="10"
                                                              Stretch="Uniform"
                                                              Fill="{DynamicResource Brush.Brand.Red}"
                                                              Data="M 2 1 L 11 6 L 2 11 Z" />
                                                    </Button>
                                                    <Button Classes="taskActionButton"
                                                            Command="{Binding ToggleCompletedCommand}"
                                                            ToolTip.Tip="{Binding ToggleTooltip}">
                                                        <Path Width="10"
                                                              Height="10"
                                                              Stretch="Uniform"
                                                              Fill="{DynamicResource Brush.Text.Primary}"
                                                              Data="M 10.8 2.2 L 5.5 10.8 L 2.2 7.5 L 3.6 6.1 L 5.3 7.8 L 9.1 1.6 Z" />
                                                    </Button>
                                                    <Button Classes="taskActionButton"
                                                            Command="{Binding DeleteTaskCommand}"
                                                            ToolTip.Tip="{Binding DeleteTaskTooltip}">
                                                        <Path Width="10"
                                                              Height="10"
                                                              Stretch="Uniform"
                                                              Fill="{DynamicResource Brush.Text.Secondary}"
                                                              Data="M 4 1 L 4.7 0 L 7.3 0 L 8 1 L 11 1 L 11 2.5 L 1 2.5 L 1 1 Z M 2.2 3.5 L 9.8 3.5 L 9.1 12 L 2.9 12 Z M 4 5 L 5.4 5 L 5.4 10.5 L 4 10.5 Z M 6.6 5 L 8 5 L 8 10.5 L 6.6 10.5 Z" />
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <TextBlock Text="{Binding EmptyTasksText}"
                                   Classes="caption"
                                   IsVisible="{Binding HasNoTodayTasks}" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
