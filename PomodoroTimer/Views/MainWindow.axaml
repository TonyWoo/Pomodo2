<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:PomodoroTimer.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1120"
        d:DesignHeight="740"
        x:Class="PomodoroTimer.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="{Binding WindowTitle}"
        Width="1120"
        Height="740"
        MinWidth="920"
        MinHeight="620"
        Background="#F4EEE4">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Button">
            <Setter Property="CornerRadius" Value="999" />
            <Setter Property="Padding" Value="20,14" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
        <Style Selector="Button.primary">
            <Setter Property="Background" Value="#C05A2B" />
            <Setter Property="Foreground" Value="#FFF9F0" />
        </Style>
        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="#F7E6D7" />
            <Setter Property="Foreground" Value="#6E3A1C" />
        </Style>
        <Style Selector="Button.ghost">
            <Setter Property="Background" Value="#FFF9F0" />
            <Setter Property="BorderBrush" Value="#D9B89D" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#8A4A26" />
        </Style>
        <Style Selector="Border.metricCard">
            <Setter Property="Background" Value="#FBF6EF" />
            <Setter Property="BorderBrush" Value="#E3D6C5" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="22" />
            <Setter Property="Padding" Value="20" />
        </Style>
    </Window.Styles>

    <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <Grid Margin="24">
            <Border Background="#FFF9F0"
                    BorderBrush="#E3D6C5"
                    BorderThickness="1"
                    CornerRadius="30"
                    Padding="32">
                <Grid RowDefinitions="Auto,*"
                      ColumnDefinitions="1.45*,1*">
                    <StackPanel Grid.ColumnSpan="2"
                                Spacing="8"
                                Margin="0,0,0,28">
                        <TextBlock Text="{Binding WindowTitle}"
                                   FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#2E4B3C" />
                        <TextBlock Text="{Binding HeroTitle}"
                                   FontSize="42"
                                   FontWeight="Bold"
                                   FontFamily="Georgia, Cambria, Times New Roman"
                                   Foreground="#3D2A1E"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Border Grid.Row="1"
                            Background="#F8F2E8"
                            CornerRadius="28"
                            Padding="30"
                            Margin="0,0,18,0">
                        <StackPanel Spacing="22">
                            <Border Background="#F7E1D5"
                                    CornerRadius="999"
                                    Padding="12,6"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="{Binding PhaseLabel}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="#A24B24" />
                            </Border>

                            <StackPanel Spacing="6">
                                <TextBlock Text="{Binding PhaseDescription}"
                                           FontSize="18"
                                           Foreground="#5F4C3F"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding FocusHint}"
                                           FontSize="14"
                                           Foreground="#8B7767"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <TextBlock Text="{Binding TimerDisplay}"
                                       FontSize="92"
                                       FontWeight="Bold"
                                       FontFamily="Georgia, Cambria, Times New Roman"
                                       Foreground="#3D2A1E" />

                            <ProgressBar Value="{Binding ProgressPercent}"
                                         Maximum="100"
                                         Height="12"
                                         Foreground="#C05A2B"
                                         Background="#E4D7C8" />

                            <Grid ColumnDefinitions="Auto,*"
                                  Margin="0,-2,0,0">
                                <TextBlock Text="{Binding ProgressLabel}"
                                           FontSize="14"
                                           Foreground="#8B7767" />
                                <TextBlock Grid.Column="1"
                                           Text="{Binding NextPhaseLabel}"
                                           HorizontalAlignment="Right"
                                           FontSize="14"
                                           Foreground="#8B7767" />
                            </Grid>

                            <Border Background="#FFF9F0"
                                    BorderBrush="#E7D8C7"
                                    BorderThickness="1"
                                    CornerRadius="20"
                                    Padding="18">
                                <TextBlock Text="{Binding StatusMessage}"
                                           FontSize="16"
                                           Foreground="#4E3B30"
                                           TextWrapping="Wrap" />
                            </Border>

                            <StackPanel Orientation="Horizontal" Spacing="12">
                                <Button Classes="primary"
                                        Command="{Binding StartPauseCommand}"
                                        Content="{Binding PrimaryActionLabel}"
                                        MinWidth="148" />
                                <Button Classes="secondary"
                                        Command="{Binding ResetCommand}"
                                        Content="{Binding ResetActionLabel}"
                                        MinWidth="116" />
                                <Button Classes="ghost"
                                        Command="{Binding SkipPhaseCommand}"
                                        Content="{Binding SkipPhaseActionLabel}"
                                        MinWidth="126" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <StackPanel Grid.Row="1"
                                Grid.Column="1"
                                Spacing="16"
                                Margin="18,0,0,0">
                        <Border Classes="metricCard">
                            <StackPanel Spacing="10">
                                <TextBlock Text="{Binding CompletedRoundsLabel}"
                                           FontSize="15"
                                           Foreground="#7A6656" />
                                <TextBlock Text="{Binding CompletedFocusSessions}"
                                           FontSize="44"
                                           FontWeight="Bold"
                                           FontFamily="Georgia, Cambria, Times New Roman"
                                           Foreground="#2E4B3C" />
                            </StackPanel>
                        </Border>

                        <Border Classes="metricCard">
                            <StackPanel Spacing="10">
                                <TextBlock Text="{Binding CurrentPaceLabel}"
                                           FontSize="15"
                                           Foreground="#7A6656" />
                                <TextBlock Text="{Binding SessionLengthLabel}"
                                           FontSize="26"
                                           FontWeight="SemiBold"
                                           Foreground="#3D2A1E"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Classes="metricCard">
                            <StackPanel Spacing="10">
                                <TextBlock Text="{Binding CycleStructureLabel}"
                                           FontSize="15"
                                           Foreground="#7A6656" />
                                <TextBlock Text="{Binding CycleOutline}"
                                           FontSize="22"
                                           FontWeight="SemiBold"
                                           Foreground="#3D2A1E"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <Border Background="#2E4B3C"
                                CornerRadius="24"
                                Padding="22">
                            <StackPanel Spacing="12">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="12">
                                    <TextBlock Text="{Binding HowToUseLabel}"
                                               FontSize="18"
                                               FontWeight="SemiBold"
                                               Foreground="#FFF7EE"
                                               VerticalAlignment="Center" />
                                    <StackPanel Grid.Column="1"
                                                Orientation="Horizontal"
                                                Spacing="8"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding LanguageSelectionLabel}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="#F5E8D7"
                                                   VerticalAlignment="Center" />
                                        <ComboBox ItemsSource="{Binding LanguageOptions}"
                                                  SelectedItem="{Binding SelectedLanguage}"
                                                  MinWidth="128" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="{Binding HowToUseSteps}"
                                           FontSize="15"
                                           Foreground="#F5E8D7"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </ScrollViewer>
</Window>
