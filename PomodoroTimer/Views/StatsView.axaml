<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PomodoroTimer.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="980"
             d:DesignHeight="720"
             x:Class="PomodoroTimer.Views.StatsView"
             x:DataType="vm:StatsViewModel">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Border Padding="{StaticResource Space.Page}">
            <StackPanel Spacing="20" MaxWidth="920">
                <StackPanel Spacing="6">
                    <TextBlock Text="{Binding PageTitle}"
                               Classes="sectionTitle" />
                    <TextBlock Text="{Binding SummaryText}"
                               Classes="caption" />
                </StackPanel>

                <WrapPanel Orientation="Horizontal">
                    <Border Classes="subtleCard"
                            Width="260"
                            Margin="0,0,16,16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{Binding TodayPomodorosLabel}"
                                       Classes="caption" />
                            <TextBlock Text="{Binding CompletedPomodoros}"
                                       Classes="metricValue" />
                        </StackPanel>
                    </Border>

                    <Border Classes="subtleCard"
                            Width="260"
                            Margin="0,0,16,16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="{Binding FocusMinutesLabel}"
                                       Classes="caption" />
                            <TextBlock Text="{Binding FocusMinutes}"
                                       Classes="metricValue" />
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <Border Classes="card">
                    <StackPanel Spacing="14">
                        <TextBlock Text="{Binding SessionsTitle}"
                                   Classes="sectionTitle" />
                        <TextBlock Text="{Binding NoSessionsText}"
                                   Classes="caption"
                                   IsVisible="{Binding ShowEmptyState}" />

                        <ItemsControl ItemsSource="{Binding Sessions}"
                                      IsVisible="{Binding HasSessions}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:SessionRowViewModel">
                                    <Border BorderBrush="{StaticResource Brush.Border.Subtle}"
                                            BorderThickness="0,0,0,1"
                                            Padding="0,12">
                                        <Grid ColumnDefinitions="*,Auto"
                                              RowDefinitions="Auto,Auto">
                                            <TextBlock Text="{Binding Topic}"
                                                       FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding StatusText}"
                                                       Foreground="{StaticResource Brush.Brand.Red}"
                                                       FontWeight="SemiBold" />
                                            <StackPanel Grid.Row="1"
                                                        Grid.ColumnSpan="2"
                                                        Orientation="Horizontal"
                                                        Spacing="12"
                                                        Margin="0,6,0,0">
                                                <TextBlock Text="{Binding CompletedTime}"
                                                           Classes="caption" />
                                                <TextBlock Text="{Binding WorkDuration}"
                                                           Classes="caption" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </ScrollViewer>
</UserControl>
