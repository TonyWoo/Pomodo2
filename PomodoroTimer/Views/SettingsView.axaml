<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PomodoroTimer.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="760"
             d:DesignHeight="660"
             x:Class="PomodoroTimer.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="{DynamicResource Thickness.Page}"
                    Spacing="18"
                    MaxWidth="680">
            <TextBlock Text="{Binding Title}"
                       Classes="pageTitle" />

            <Border Classes="card">
                <StackPanel Spacing="18">
                    <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                          RowDefinitions="Auto,Auto">
                        <StackPanel Grid.Column="0"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding WorkDurationLabel}"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding MinutesLabel}"
                                       Classes="caption" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Classes="secondary"
                                MinWidth="44"
                                Content="-"
                                Command="{Binding DecreaseWorkDurationCommand}" />
                        <Border Grid.Column="2"
                                Background="{DynamicResource Brush.Surface.Secondary}"
                                BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource Radius.Medium}"
                                MinWidth="96"
                                MinHeight="{DynamicResource Size.TouchTarget}"
                                Margin="8,0"
                                Padding="18,8">
                            <TextBlock Text="{Binding WorkDurationMinutes}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center" />
                        </Border>
                        <Button Grid.Column="3"
                                Classes="secondary"
                                MinWidth="44"
                                Content="+"
                                Command="{Binding IncreaseWorkDurationCommand}" />
                    </Grid>

                    <Grid ColumnDefinitions="*,Auto,Auto,Auto"
                          RowDefinitions="Auto,Auto">
                        <StackPanel Grid.Column="0"
                                    VerticalAlignment="Center">
                            <TextBlock Text="{Binding BreakDurationLabel}"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="{Binding MinutesLabel}"
                                       Classes="caption" />
                        </StackPanel>
                        <Button Grid.Column="1"
                                Classes="secondary"
                                MinWidth="44"
                                Content="-"
                                Command="{Binding DecreaseBreakDurationCommand}" />
                        <Border Grid.Column="2"
                                Background="{DynamicResource Brush.Surface.Secondary}"
                                BorderBrush="{DynamicResource Brush.Border.Subtle}"
                                BorderThickness="1"
                                CornerRadius="{DynamicResource Radius.Medium}"
                                MinWidth="96"
                                MinHeight="{DynamicResource Size.TouchTarget}"
                                Margin="8,0"
                                Padding="18,8">
                            <TextBlock Text="{Binding BreakDurationMinutes}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center" />
                        </Border>
                        <Button Grid.Column="3"
                                Classes="secondary"
                                MinWidth="44"
                                Content="+"
                                Command="{Binding IncreaseBreakDurationCommand}" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Classes="card">
                <StackPanel Spacing="14">
                    <TextBlock Text="{Binding PresetsLabel}"
                               Classes="sectionTitle" />
                    <Grid ColumnDefinitions="*,*,*">
                        <ToggleButton Grid.Column="0"
                                Classes="presetButton"
                                IsChecked="{Binding IsPreset25_5Active, Mode=OneWay}"
                                Content="{Binding PresetTwentyFiveFiveText}"
                                Command="{Binding ApplyPresetCommand}"
                                CommandParameter="25/5" />
                        <ToggleButton Grid.Column="1"
                                Classes="presetButton"
                                Margin="10,0"
                                IsChecked="{Binding IsPreset50_5Active, Mode=OneWay}"
                                Content="{Binding PresetFiftyFiveText}"
                                Command="{Binding ApplyPresetCommand}"
                                CommandParameter="50/5" />
                        <ToggleButton Grid.Column="2"
                                Classes="presetButton"
                                IsChecked="{Binding IsPresetCustomActive, Mode=OneWay}"
                                Content="{Binding CustomLabel}"
                                Command="{Binding ApplyPresetCommand}"
                                CommandParameter="custom" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Classes="card">
                <StackPanel Spacing="12">
                    <TextBlock Text="{Binding LanguageLabel}"
                               Classes="sectionTitle" />
                    <ComboBox ItemsSource="{Binding LanguageOptions}"
                              SelectedItem="{Binding SelectedLanguage}"
                              HorizontalAlignment="Stretch" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
