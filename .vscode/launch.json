{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run (macOS / Windows Desktop)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-desktop",
      "program": "${workspaceFolder}/PomodoroTimer.Desktop/bin/Debug/net8.0/PomodoroTimer.Desktop",
      "args": [],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "env": {
        "DOTNET_ENVIRONMENT": "Development"
      }
    },
    {
      "name": "Debug (macOS / Windows Desktop)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-desktop",
      "program": "${workspaceFolder}/PomodoroTimer.Desktop/bin/Debug/net8.0/PomodoroTimer.Desktop",
      "args": [],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "env": {
        "DOTNET_ENVIRONMENT": "Development"
      },
      "console": "internalConsole"
    },
    {
      "name": "Run (iOS Simulator)",
      "type": "node",
      "request": "launch",
      "preLaunchTask": "run-ios",
      "runtimeExecutable": "echo",
      "runtimeArgs": ["iOS app launched via run-ios task"],
      "console": "internalConsole"
    }
  ]
}
